            "url": {
              "raw": "{{baseUrl}}/admin/projects/:id",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3001",
              "path": ["admin", "projects", ":id"]
            }
          }
        },
        {
          "name": "PATCH Toggle Active / Archive",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{JWT_TOKEN}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"isArchived\": true\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/admin/projects/:id",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3001",
              "path": ["admin", "projects", ":id"]
            }
          }
        },
        {
          "name": "DELETE Archive Project (soft-delete)",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{JWT_TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/projects/:id",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3001",
              "path": ["admin", "projects", ":id"]
            }
          }
        }
