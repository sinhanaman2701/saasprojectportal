{
  "info": {
    "name": "Kolte Patil Portal API",
    "description": "Backend API for Kolte Patil Admin Portal & Mobile App. Auth: POST /admin/auth/login → use token as Bearer <JWT_TOKEN>.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3001"
    },
    {
      "key": "JWT_TOKEN",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.response_data && jsonData.response_data.token) {",
                  "    pm.collectionVariables.set('JWT_TOKEN', jsonData.response_data.token);",
                  "}",
                  "pm.test('Has token', function() {",
                  "    pm.expect(jsonData.response_data.token).to.be.ok;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@koltepatil.test\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/admin/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3001",
              "path": ["admin", "auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "Admin - Projects",
      "item": [
        {
          "name": "GET All Projects",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{JWT_TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/projects?includeArchived=false",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3001",
              "path": ["admin", "projects"],
              "query": [
                {
                  "key": "includeArchived",
                  "value": "false",
                  "description": "true | false — whether to include archived projects"
                }
              ]
            }
          }
        },
        {
          "name": "POST Create Project (Multipart)",
          "request": {
            "method": "POST",
